# ════════════════════════════════════════
# BigLinker LMS — 환경변수 설정
# cp .env.example .env  후 값을 채우세요
# ════════════════════════════════════════

# ── 필수 설정 ──────────────────────────
# JWT 시크릿 (반드시 변경! 최소 32자 랜덤 문자열)
# 생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=여기에-랜덤-64자-문자열-입력

# Anthropic Claude API 키 (https://console.anthropic.com)
# 관리자 페이지 설정에서도 등록 가능
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── 서버 설정 ──────────────────────────
NODE_ENV=production
PORT=3000

# ── 데이터 저장 경로 ───────────────────
# Railway/Render 볼륨 마운트: /data/biglinker.db
DB_PATH=./biglinker.db
UPLOADS_DIR=./uploads

# ── CORS (도메인 설정 후 반드시 변경) ──
# 예: https://biglinker.kr,https://www.biglinker.kr
# 개발 중: *
ALLOWED_ORIGINS=*
